---
import Layout from '../../layouts/Layout.astro';
import { getCollection } from 'astro:content';
import { getCategories, getGrafy, categoryColor, categoryDescription } from '../../lib/rh';

const stattii = await getCollection('rh');
const sorted = stattii.sort((a, b) => a.data.stattia - b.data.stattia);
const grafy = getGrafy();
const cats = getCategories();

// Готуємо плоский JSON для клієнта: список статей з пунктами і графами.
const data = sorted.map((s) => ({
  stattia: s.data.stattia,
  nazva: s.data.nazva,
  short_nazva: s.data.short_nazva ?? s.data.nazva,
  klas: s.data.klas,
  punkty: s.data.punkty.map((p: any) => ({
    id: p.id,
    opys: p.opys,
    grafy: p.grafy,
  })),
}));
const catMap = Object.fromEntries(cats.map((c) => [c.code, c.description]));
const grafaAud = Object.fromEntries(grafy.map((g) => [g.code, g.audience]));
---
<Layout
  title="Калькулятор придатності"
  description="Інтерактивний калькулятор категорії придатності до військової служби за Розкладом хвороб."
>
  <div class="mb-4 px-4 py-3 rounded-md bg-amber-50 dark:bg-amber-900/20 border-l-2 border-amber-500 text-sm text-amber-800 dark:text-amber-200 mt-6">
    <strong>Демо-калькулятор.</strong> Працює на ілюстративних даних 3 статей.
    Результат не може замінити рішення ВЛК. Перед рішеннями — звіряйте з
    <a href="https://zakon.rada.gov.ua/laws/show/z1109-08" target="_blank" rel="noopener" class="underline">офіційним текстом</a>.
  </div>

  <h1 class="text-3xl font-bold tracking-tight mt-6 mb-2">Калькулятор придатності</h1>
  <p class="text-ink-500 mb-8 max-w-2xl">
    Оберіть контингент і знайдіть статтю Розкладу хвороб + конкретний пункт —
    отримаєте категорію придатності з поясненням.
  </p>

  <div class="grid lg:grid-cols-2 gap-6">
    <section class="space-y-4">
      <div>
        <label for="contingent" class="block text-sm font-medium mb-2">1. Контингент</label>
        <div class="grid grid-cols-1 gap-2">
          {grafy.map((g, i) => (
            <label class="flex items-baseline gap-3 p-3 rounded-md border border-ink-200 dark:border-ink-800 cursor-pointer hover:border-accent-500 has-[:checked]:border-accent-500 has-[:checked]:bg-accent-50 dark:has-[:checked]:bg-accent-900/20">
              <input type="radio" name="contingent" value={g.code} class="mt-1 accent-accent-500" checked={i === 0} />
              <div>
                <div class="font-mono text-xs text-accent-600 dark:text-accent-300">{g.label}</div>
                <div class="text-sm font-medium">{g.audience}</div>
              </div>
            </label>
          ))}
        </div>
      </div>

      <div>
        <label for="stattia" class="block text-sm font-medium mb-2">2. Стаття (нозологія)</label>
        <select id="stattia" class="w-full p-2 rounded-md border border-ink-200 dark:border-ink-700 bg-white dark:bg-ink-950 text-sm">
          {sorted.map((s) => (
            <option value={s.data.stattia}>Ст. {s.data.stattia}. {s.data.nazva}</option>
          ))}
        </select>
      </div>

      <div>
        <label for="punkt" class="block text-sm font-medium mb-2">3. Пункт (ступінь тяжкості)</label>
        <div id="punkt-options" class="space-y-2"></div>
      </div>
    </section>

    <section>
      <div class="text-sm font-medium mb-2">Результат</div>
      <div id="result" class="rounded-md border border-ink-200 dark:border-ink-800 p-6 text-center">
        <div class="text-ink-500 text-sm">Оберіть пункт ↑</div>
      </div>
      <details class="mt-4 text-sm">
        <summary class="cursor-pointer text-ink-500 hover:text-ink-700 dark:hover:text-ink-300">Що означають категорії?</summary>
        <ul class="mt-2 space-y-1">
          {cats.map((c) => (
            <li class="flex items-baseline gap-2">
              <span class:list={['inline-block px-1.5 py-0.5 rounded font-mono text-[10px] font-semibold min-w-[2.5rem] text-center', categoryColor(c.code)]}>{c.code}</span>
              <span class="text-xs text-ink-500">{c.description}</span>
            </li>
          ))}
        </ul>
      </details>
    </section>
  </div>

  <script is:inline define:vars={{ data, catMap, grafaAud }}>
    (function () {
      const $ = (s) => document.querySelector(s);
      const $$ = (s) => document.querySelectorAll(s);
      const stattiaSel = $('#stattia');
      const punktBox = $('#punkt-options');
      const resultBox = $('#result');

      function currentContingent() {
        const r = document.querySelector('input[name="contingent"]:checked');
        return r ? r.value : 'I';
      }

      function currentStattia() {
        const v = parseInt(stattiaSel.value, 10);
        return data.find((s) => s.stattia === v) || data[0];
      }

      function renderPunkty() {
        const s = currentStattia();
        punktBox.innerHTML = s.punkty.map((p, i) => {
          const inputId = `pkt-${p.id}`;
          return `
            <label for="${inputId}" class="flex items-baseline gap-3 p-3 rounded-md border border-ink-200 dark:border-ink-800 cursor-pointer hover:border-accent-500 has-[:checked]:border-accent-500 has-[:checked]:bg-accent-50 dark:has-[:checked]:bg-accent-900/20">
              <input id="${inputId}" type="radio" name="punkt" value="${p.id}" class="mt-1 accent-accent-500" ${i === 0 ? 'checked' : ''}/>
              <div>
                <div class="font-mono text-xs text-accent-600 dark:text-accent-300">пункт ${p.id})</div>
                <div class="text-sm">${p.opys}</div>
              </div>
            </label>
          `;
        }).join('');
        punktBox.querySelectorAll('input[name="punkt"]').forEach((el) => {
          el.addEventListener('change', renderResult);
        });
        renderResult();
      }

      const CAT_COLOR = {
        'А':   'bg-emerald-100 text-emerald-800 dark:bg-emerald-900/40 dark:text-emerald-300',
        'А-1': 'bg-emerald-100 text-emerald-800 dark:bg-emerald-900/40 dark:text-emerald-300',
        'Б':   'bg-yellow-100 text-yellow-800 dark:bg-yellow-900/40 dark:text-yellow-300',
        'Б-1': 'bg-yellow-100 text-yellow-800 dark:bg-yellow-900/40 dark:text-yellow-300',
        'Б-2': 'bg-yellow-100 text-yellow-800 dark:bg-yellow-900/40 dark:text-yellow-300',
        'Б-3': 'bg-yellow-100 text-yellow-800 dark:bg-yellow-900/40 dark:text-yellow-300',
        'Б-4': 'bg-yellow-100 text-yellow-800 dark:bg-yellow-900/40 dark:text-yellow-300',
        'В':   'bg-orange-100 text-orange-800 dark:bg-orange-900/40 dark:text-orange-300',
        'Г':   'bg-amber-100 text-amber-800 dark:bg-amber-900/40 dark:text-amber-300',
        'Д':   'bg-red-100 text-red-800 dark:bg-red-900/40 dark:text-red-300',
      };

      function renderResult() {
        const s = currentStattia();
        const g = currentContingent();
        const selPunkt = document.querySelector('input[name="punkt"]:checked');
        if (!selPunkt) {
          resultBox.innerHTML = '<div class="text-ink-500 text-sm">Оберіть пункт ↑</div>';
          return;
        }
        const p = s.punkty.find((x) => x.id === selPunkt.value);
        const cat = p.grafy[g] || '—';
        const desc = catMap[cat] || 'Категорія не визначена для цього контингенту';
        const aud = grafaAud[g];
        const color = CAT_COLOR[cat] || 'bg-ink-100 text-ink-700 dark:bg-ink-800 dark:text-ink-300';
        resultBox.innerHTML = `
          <div class="text-xs text-ink-500 uppercase tracking-wider font-medium mb-1">Категорія</div>
          <div class="inline-block px-6 py-3 rounded-md font-mono text-4xl font-bold ${color}">${cat}</div>
          <div class="mt-3 text-base font-medium">${desc}</div>
          <div class="mt-4 text-xs text-ink-500 leading-relaxed text-left max-w-md mx-auto">
            <strong>Контекст:</strong> Граф ${g} (${aud}). Стаття ${s.stattia} «${s.short_nazva}», пункт ${p.id}) — ${p.opys}
          </div>
          <a href="/rh/${String(s.stattia).padStart(3, '0')}/" class="inline-block mt-4 text-xs text-accent-600 dark:text-accent-300 hover:underline">Повна таблиця статті ↗</a>
        `;
      }

      stattiaSel.addEventListener('change', renderPunkty);
      document.querySelectorAll('input[name="contingent"]').forEach((el) => el.addEventListener('change', renderResult));
      renderPunkty();
    })();
  </script>
</Layout>

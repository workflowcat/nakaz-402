---
import Layout from '../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const chapters = await getCollection('polozhennia');
const realChapters = chapters.filter(c => c.data.type === 'glava');
const filled = realChapters.filter(c => !c.data.stub);
const drafts = await getCollection('drafts');
const activeDrafts = drafts.filter((d: any) => d.data.status !== 'rejected' && d.data.status !== 'adopted');
---
<Layout title="Головна">
  <section class="py-12 sm:py-16">
    <p class="text-xs uppercase tracking-widest text-accent-600 dark:text-accent-300 font-medium mb-4 flex items-center gap-3">
      <span class="w-8 h-px bg-accent-500/60"></span>
      Наказ МОУ № 402 · 14.08.2008
    </p>
    <h1 class="text-4xl sm:text-5xl font-extrabold tracking-tight leading-[1.05] max-w-2xl">
      Військово-лікарська експертиза як дані, а не як docx
    </h1>
    <p class="mt-5 text-lg text-ink-500 dark:text-ink-400 max-w-2xl leading-relaxed">
      Той самий нормативний акт, але кожен пункт має стабільний id, кожна правка
      видима у git, а Розклад хвороб — таблиця, з якої можна порахувати придатність скриптом.
    </p>
    <div class="mt-6 flex flex-wrap gap-2">
      <a href="/changes/" class="inline-flex items-center px-4 py-2 rounded-md bg-accent-500 text-white text-sm font-medium hover:bg-accent-600 transition-colors">Усі зміни →</a>
      <a href="/drafts/" class="inline-flex items-center px-4 py-2 rounded-md border border-accent-500 text-accent-600 dark:text-accent-300 text-sm font-medium hover:bg-accent-50 dark:hover:bg-accent-900/20 transition-colors">
        Драфти {activeDrafts.length > 0 && <span class="ml-1.5 px-1.5 py-0.5 rounded bg-accent-500 text-white text-[10px] font-mono">{activeDrafts.length}</span>}
      </a>
      <a href="/polozhennia/" class="inline-flex items-center px-4 py-2 rounded-md border border-ink-200 dark:border-ink-700 text-sm font-medium hover:border-accent-500 hover:text-accent-600 dark:hover:text-accent-300 transition-colors">Положення</a>
      <a href="/nakaz/" class="inline-flex items-center px-4 py-2 rounded-md border border-ink-200 dark:border-ink-700 text-sm font-medium hover:border-accent-500 hover:text-accent-600 dark:hover:text-accent-300 transition-colors">Прочитати наказ</a>
    </div>
  </section>

  <section class="grid grid-cols-2 sm:grid-cols-4 gap-3 my-8">
    <div class="bg-ink-50 dark:bg-ink-900 border-l-2 border-accent-500 px-4 py-3 rounded-r-md">
      <div class="text-3xl font-bold tabular-nums tracking-tight">{realChapters.length}</div>
      <div class="text-[11px] uppercase tracking-wider text-ink-500 mt-1 font-medium">глав структурно</div>
    </div>
    <div class="bg-ink-50 dark:bg-ink-900 border-l-2 border-accent-500 px-4 py-3 rounded-r-md">
      <div class="text-3xl font-bold tabular-nums tracking-tight">{filled.length}</div>
      <div class="text-[11px] uppercase tracking-wider text-ink-500 mt-1 font-medium">з повним текстом</div>
    </div>
    <div class="bg-ink-50 dark:bg-ink-900 border-l-2 border-accent-500 px-4 py-3 rounded-r-md">
      <div class="text-3xl font-bold tabular-nums tracking-tight">23</div>
      <div class="text-[11px] uppercase tracking-wider text-ink-500 mt-1 font-medium">амендментів</div>
    </div>
    <div class="bg-ink-50 dark:bg-ink-900 border-l-2 border-accent-500 px-4 py-3 rounded-r-md">
      <div class="text-3xl font-bold tabular-nums tracking-tight">2008—2025</div>
      <div class="text-[11px] uppercase tracking-wider text-ink-500 mt-1 font-medium">діапазон</div>
    </div>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold tracking-tight mb-4 pt-3 border-t border-ink-200 dark:border-ink-800 relative">
      <span class="absolute -top-px left-0 w-9 h-px bg-accent-500"></span>
      Глави з повним текстом
    </h2>
    <ul class="divide-y divide-ink-200 dark:divide-ink-800 border-y border-ink-200 dark:border-ink-800">
      {filled.slice(0, 10).map(c => (
        <li>
          <a href={`/polozhennia/${c.id.replace(/\.md$/, '')}/`} class="block py-3 px-2 hover:bg-ink-50 dark:hover:bg-ink-900 transition-colors group">
            <div class="flex items-baseline justify-between gap-4">
              <div>
                <div class="font-medium">{c.data.title}</div>
                <div class="text-xs text-ink-500 mt-0.5 font-mono">{c.data.id}</div>
              </div>
              <span class="text-ink-400 group-hover:text-accent-500">→</span>
            </div>
          </a>
        </li>
      ))}
    </ul>
    <a href="/polozhennia/" class="inline-block mt-4 text-sm text-accent-600 dark:text-accent-300 hover:underline">Усі {realChapters.length} глав →</a>
  </section>

  <section class="mt-16">
    <h2 class="text-xl font-bold tracking-tight mb-2 pt-3 border-t border-ink-200 dark:border-ink-800 relative">
      <span class="absolute -top-px left-0 w-9 h-px bg-accent-500"></span>
      Якщо ви готуєте зміну до Положення
    </h2>
    <p class="text-sm text-ink-500 mb-5 max-w-3xl leading-relaxed">
      Для юристів МОУ, експертів ЦВЛК, адвокаційних організацій
      (Veteran Hub, Right to Protection) і всіх, хто пише пропозиції до
      Наказу № 402. Опишіть бажану правку як список операцій —
      сайт сам перевірить помилки в посиланнях, виявить конфлікти з іншими
      проєктами, відстежить застарілу термінологію і згенерує готовий
      текст «Внести зміни...» для офіційного наказу.
      <span class="block mt-2 text-amber-600 dark:text-amber-300">⚠️ Проєкти тут — це робочі чернетки, а не офіційні НПА. Юридичної сили вони не мають.</span>
    </p>
    <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-3">
      <a href="/drafts/" class="block p-4 rounded-md border border-accent-300 dark:border-accent-700 bg-accent-50/40 dark:bg-accent-900/10 hover:bg-accent-50 dark:hover:bg-accent-900/20 transition-colors">
        <div class="text-sm font-medium text-accent-600 dark:text-accent-300 mb-1">📝 Робочі проєкти</div>
        <div class="font-medium mb-1">{activeDrafts.length} активн{activeDrafts.length === 1 ? 'ий проєкт' : 'их проєкти'}</div>
        <div class="text-xs text-ink-500">Чернетки і пропозиції на огляді. Для кожного — наочна різниця «чинна редакція / пропонована».</div>
      </a>
      <div class="block p-4 rounded-md border border-ink-200 dark:border-ink-800">
        <div class="text-sm font-medium text-accent-600 dark:text-accent-300 mb-1">⚠️ Автоперевірки</div>
        <div class="font-medium mb-1">6 правил</div>
        <div class="text-xs text-ink-500">Чи існує пункт-ціль, чи унікальний новий номер, чи нема конфліктів і застарілих термінів.</div>
      </div>
      <div class="block p-4 rounded-md border border-ink-200 dark:border-ink-800">
        <div class="text-sm font-medium text-accent-600 dark:text-accent-300 mb-1">📜 Готовий текст наказу</div>
        <div class="font-medium mb-1">Авто-генерація «Внести зміни...»</div>
        <div class="text-xs text-ink-500">З правильними відмінками («пункту 1.4 глави 1 розділу I») — як у справжніх амендментах МОУ.</div>
      </div>
      <a href="https://github.com/workflowcat/nakaz-402/tree/main/drafts" target="_blank" rel="noopener" class="block p-4 rounded-md border border-ink-200 dark:border-ink-800 hover:border-accent-500 hover:bg-ink-50 dark:hover:bg-ink-900 transition-colors">
        <div class="text-sm font-medium text-accent-600 dark:text-accent-300 mb-1">✏️ Подати свій проєкт</div>
        <div class="font-medium mb-1">через GitHub-PR</div>
        <div class="text-xs text-ink-500">Один файл у папці <code class="font-mono text-[10px]">drafts/</code>, опис правок у YAML — сайт автоматично згенерує сторінку.</div>
      </a>
    </div>
  </section>

  <section class="mt-16">
    <h2 class="text-xl font-bold tracking-tight mb-2 pt-3 border-t border-ink-200 dark:border-ink-800 relative">
      <span class="absolute -top-px left-0 w-9 h-px bg-accent-500"></span>
      Для інших інструментів
    </h2>
    <p class="text-sm text-ink-500 mb-5">Усе під CC0. Без ключів, без rate-limit. Серверна частина — статичні файли на CDN.</p>
    <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-3">
      <a href="/api/docs/" class="block p-4 rounded-md border border-ink-200 dark:border-ink-800 hover:border-accent-500 hover:bg-ink-50 dark:hover:bg-ink-900 transition-colors">
        <div class="text-sm font-mono text-accent-600 dark:text-accent-300 mb-1">📡 JSON API</div>
        <div class="font-medium mb-1">/api/</div>
        <div class="text-xs text-ink-500">OpenAPI 3.1 · CORS-open · ~10 ендпоінтів</div>
      </a>
      <a href="/embed/" class="block p-4 rounded-md border border-ink-200 dark:border-ink-800 hover:border-accent-500 hover:bg-ink-50 dark:hover:bg-ink-900 transition-colors">
        <div class="text-sm font-mono text-accent-600 dark:text-accent-300 mb-1">🧩 Embed widget</div>
        <div class="font-medium mb-1">&lt;nakaz-402-punkt&gt;</div>
        <div class="text-xs text-ink-500">Один script-тег. Shadow DOM. Темна тема.</div>
      </a>
      <a href="https://github.com/workflowcat/nakaz-402/tree/main/web/packages/nakaz-402-mcp" target="_blank" rel="noopener" class="block p-4 rounded-md border border-ink-200 dark:border-ink-800 hover:border-accent-500 hover:bg-ink-50 dark:hover:bg-ink-900 transition-colors">
        <div class="text-sm font-mono text-accent-600 dark:text-accent-300 mb-1">🤖 MCP server</div>
        <div class="font-medium mb-1">nakaz-402-mcp</div>
        <div class="text-xs text-ink-500">Запитуйте Claude / Cursor / Zed простою мовою</div>
      </a>
      <a href="https://github.com/workflowcat/nakaz-402/tree/main/web/packages/nakaz-402" target="_blank" rel="noopener" class="block p-4 rounded-md border border-ink-200 dark:border-ink-800 hover:border-accent-500 hover:bg-ink-50 dark:hover:bg-ink-900 transition-colors">
        <div class="text-sm font-mono text-accent-600 dark:text-accent-300 mb-1">📦 npm package</div>
        <div class="font-medium mb-1">nakaz-402</div>
        <div class="text-xs text-ink-500">Типовий клієнт. Zero deps. Browser / Node / Deno / Bun.</div>
      </a>
      <a href="/changes/rss.xml" class="block p-4 rounded-md border border-ink-200 dark:border-ink-800 hover:border-accent-500 hover:bg-ink-50 dark:hover:bg-ink-900 transition-colors">
        <div class="text-sm font-mono text-accent-600 dark:text-accent-300 mb-1">📰 RSS / Atom</div>
        <div class="font-medium mb-1">/changes/rss.xml</div>
        <div class="text-xs text-ink-500">Підпишіться на нові амендменти у своєму ріді</div>
      </a>
      <a href="https://github.com/workflowcat/nakaz-402" target="_blank" rel="noopener" class="block p-4 rounded-md border border-ink-200 dark:border-ink-800 hover:border-accent-500 hover:bg-ink-50 dark:hover:bg-ink-900 transition-colors">
        <div class="text-sm font-mono text-accent-600 dark:text-accent-300 mb-1">🔧 GitHub</div>
        <div class="font-medium mb-1">workflowcat/nakaz-402</div>
        <div class="text-xs text-ink-500">Issues, PRs, raw Markdown — рідне ваше середовище</div>
      </a>
    </div>
  </section>
</Layout>

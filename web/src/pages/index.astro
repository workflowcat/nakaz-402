---
import Layout from '../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const chapters = await getCollection('polozhennia');
const realChapters = chapters.filter(c => c.data.type === 'glava');
const filled = realChapters.filter(c => !c.data.stub);
---
<Layout title="Головна">
  <section class="py-12 sm:py-16">
    <p class="text-xs uppercase tracking-widest text-accent-600 dark:text-accent-300 font-medium mb-4 flex items-center gap-3">
      <span class="w-8 h-px bg-accent-500/60"></span>
      Наказ МОУ № 402 · 14.08.2008
    </p>
    <h1 class="text-4xl sm:text-5xl font-extrabold tracking-tight leading-[1.05] max-w-2xl">
      Військово-лікарська експертиза як дані, а не як docx
    </h1>
    <p class="mt-5 text-lg text-ink-500 dark:text-ink-400 max-w-2xl leading-relaxed">
      Той самий нормативний акт, але кожен пункт має стабільний id, кожна правка
      видима у git, а Розклад хвороб — таблиця, з якої можна порахувати придатність скриптом.
    </p>
    <div class="mt-6 flex flex-wrap gap-2">
      <a href="/changes/" class="inline-flex items-center px-4 py-2 rounded-md bg-accent-500 text-white text-sm font-medium hover:bg-accent-600 transition-colors">Усі зміни →</a>
      <a href="/nakaz/" class="inline-flex items-center px-4 py-2 rounded-md border border-ink-200 dark:border-ink-700 text-sm font-medium hover:border-accent-500 hover:text-accent-600 dark:hover:text-accent-300 transition-colors">Прочитати наказ</a>
      <a href="/polozhennia/" class="inline-flex items-center px-4 py-2 rounded-md border border-ink-200 dark:border-ink-700 text-sm font-medium hover:border-accent-500 hover:text-accent-600 dark:hover:text-accent-300 transition-colors">Положення</a>
    </div>
  </section>

  <section class="grid grid-cols-2 sm:grid-cols-4 gap-3 my-8">
    <div class="bg-ink-50 dark:bg-ink-900 border-l-2 border-accent-500 px-4 py-3 rounded-r-md">
      <div class="text-3xl font-bold tabular-nums tracking-tight">{realChapters.length}</div>
      <div class="text-[11px] uppercase tracking-wider text-ink-500 mt-1 font-medium">глав структурно</div>
    </div>
    <div class="bg-ink-50 dark:bg-ink-900 border-l-2 border-accent-500 px-4 py-3 rounded-r-md">
      <div class="text-3xl font-bold tabular-nums tracking-tight">{filled.length}</div>
      <div class="text-[11px] uppercase tracking-wider text-ink-500 mt-1 font-medium">з повним текстом</div>
    </div>
    <div class="bg-ink-50 dark:bg-ink-900 border-l-2 border-accent-500 px-4 py-3 rounded-r-md">
      <div class="text-3xl font-bold tabular-nums tracking-tight">23</div>
      <div class="text-[11px] uppercase tracking-wider text-ink-500 mt-1 font-medium">амендментів</div>
    </div>
    <div class="bg-ink-50 dark:bg-ink-900 border-l-2 border-accent-500 px-4 py-3 rounded-r-md">
      <div class="text-3xl font-bold tabular-nums tracking-tight">2008—2025</div>
      <div class="text-[11px] uppercase tracking-wider text-ink-500 mt-1 font-medium">діапазон</div>
    </div>
  </section>

  <section class="mt-10">
    <h2 class="text-xl font-bold tracking-tight mb-4 pt-3 border-t border-ink-200 dark:border-ink-800 relative">
      <span class="absolute -top-px left-0 w-9 h-px bg-accent-500"></span>
      Глави з повним текстом
    </h2>
    <ul class="divide-y divide-ink-200 dark:divide-ink-800 border-y border-ink-200 dark:border-ink-800">
      {filled.slice(0, 10).map(c => (
        <li>
          <a href={`/polozhennia/${c.id.replace(/\.md$/, '')}/`} class="block py-3 px-2 hover:bg-ink-50 dark:hover:bg-ink-900 transition-colors group">
            <div class="flex items-baseline justify-between gap-4">
              <div>
                <div class="font-medium">{c.data.title}</div>
                <div class="text-xs text-ink-500 mt-0.5 font-mono">{c.data.id}</div>
              </div>
              <span class="text-ink-400 group-hover:text-accent-500">→</span>
            </div>
          </a>
        </li>
      ))}
    </ul>
    <a href="/polozhennia/" class="inline-block mt-4 text-sm text-accent-600 dark:text-accent-300 hover:underline">Усі {realChapters.length} глав →</a>
  </section>
</Layout>

---
import Layout from '../../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const drafts = await getCollection('drafts');
const sorted = drafts.sort((a, b) => {
  const da = String(a.data.proposed_at ?? '');
  const db = String(b.data.proposed_at ?? '');
  return db.localeCompare(da);
});

function fmtDate(v: string | Date | undefined | null): string {
  if (!v) return '';
  if (v instanceof Date) return v.toISOString().slice(0, 10);
  const m = String(v).match(/\d{4}-\d{2}-\d{2}/);
  return m ? m[0] : String(v).slice(0, 10);
}

const STATUS_LABEL: Record<string, string> = {
  draft: 'чернетка',
  review: 'на огляді',
  adopted: 'прийнято',
  rejected: 'відхилено',
};
const STATUS_COLOR: Record<string, string> = {
  draft:    'bg-amber-100 text-amber-800 dark:bg-amber-900/40 dark:text-amber-300',
  review:   'bg-blue-100 text-blue-800 dark:bg-blue-900/40 dark:text-blue-300',
  adopted:  'bg-emerald-100 text-emerald-800 dark:bg-emerald-900/40 dark:text-emerald-300',
  rejected: 'bg-ink-200 text-ink-600 dark:bg-ink-800 dark:text-ink-400',
};
---
<Layout
  title="Проєкти амендментів"
  description="Машино-читабельні проєкти правок до Наказу МОУ № 402. Не є офіційними НПА."
>
  <div class="mb-4 px-4 py-3 rounded-md bg-amber-50 dark:bg-amber-900/20 border-l-2 border-amber-500 text-sm text-amber-800 dark:text-amber-200 mt-6">
    <strong>Це НЕ офіційні проєкти нормативно-правових актів.</strong>
    Тут — машино-читабельні ескізи правок від громади, юристів МОУ, ЦВЛК-експертів
    і адвокаційних організацій. Авторитет — лише прийнятий і зареєстрований наказ.
  </div>

  <h1 class="text-3xl font-bold tracking-tight mb-3">Проєкти амендментів</h1>
  <p class="text-ink-500 mb-8">
    <strong>{drafts.length}</strong> {drafts.length === 1 ? 'проєкт' : drafts.length < 5 ? 'проєкти' : 'проєктів'} у системі.
    Подати свій → <a href="https://github.com/workflowcat/nakaz-402/tree/main/drafts" target="_blank" rel="noopener" class="text-accent-600 dark:text-accent-300 underline">drafts/ на GitHub</a>.
  </p>

  {sorted.length === 0 ? (
    <p class="text-ink-500 italic">Ще немає жодного проєкту.</p>
  ) : (
    <ul class="space-y-3">
      {sorted.map((d) => (
        <li>
          <a
            href={`/drafts/${d.id.replace(/\.md$/, '')}/`}
            class="block p-4 rounded-md border border-ink-200 dark:border-ink-800 hover:border-accent-500 hover:bg-ink-50 dark:hover:bg-ink-900 transition-colors"
          >
            <div class="flex items-baseline justify-between gap-3 flex-wrap mb-1">
              <span class:list={['text-[10px] font-mono uppercase tracking-wider px-1.5 py-0.5 rounded', STATUS_COLOR[d.data.status] ?? STATUS_COLOR.draft]}>{STATUS_LABEL[d.data.status] ?? d.data.status}</span>
              <span class="font-mono text-xs text-ink-500">{d.data.id}</span>
            </div>
            <div class="font-medium mb-1">{d.data.title}</div>
            {d.data.short_summary && (
              <div class="text-sm text-ink-500 line-clamp-2">{d.data.short_summary}</div>
            )}
            <div class="text-xs text-ink-500 mt-2 font-mono flex gap-3">
              {d.data.proposed_by && <span>👤 {d.data.proposed_by}</span>}
              {d.data.proposed_at && <span>📅 {fmtDate(d.data.proposed_at)}</span>}
              <span class="ml-auto">{d.data.operations?.length ?? 0} {(d.data.operations?.length ?? 0) === 1 ? 'операція' : (d.data.operations?.length ?? 0) < 5 ? 'операції' : 'операцій'}</span>
            </div>
          </a>
        </li>
      ))}
    </ul>
  )}
</Layout>

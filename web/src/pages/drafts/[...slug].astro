---
import Layout from '../../layouts/Layout.astro';
import { getCollection, render } from 'astro:content';
import { resolveTarget, wordDiff, diffBefore, diffAfter, buildPunktIdIndex, lintDraft, lintTerminology, generateCitation } from '../../lib/drafts';

export async function getStaticPaths() {
  const drafts = await getCollection('drafts');
  return drafts
    .filter(d => !d.id.toLowerCase().endsWith('readme.md'))
    .map(d => ({
      params: { slug: d.id.replace(/\.md$/, '') },
      props: { entry: d },
    }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);
const githubEditUrl = `https://github.com/workflowcat/nakaz-402/edit/main/drafts/${entry.id}`;

// Resolve every operation's target so we can show a before/after preview.
const resolvedOps = await Promise.all(
  (entry.data.operations ?? []).map(async (op: any) => {
    const refId = op.target ?? op.after ?? op.before ?? null;
    const resolved = refId ? await resolveTarget(refId) : null;
    return { op, resolved };
  })
);

// Lint this draft against the canonical pункт index + all other drafts.
const allDrafts = await getCollection('drafts');
const otherDrafts = allDrafts.filter((d) => d.id !== entry.id);
const knownIds = await buildPunktIdIndex();
const findings = [
  ...lintDraft(entry as any, knownIds, otherDrafts as any),
  ...lintTerminology(entry as any),
];
const errorCount = findings.filter((f) => f.level === 'error').length;
const warningCount = findings.filter((f) => f.level === 'warning').length;

const citation = generateCitation(entry as any);

function strip(text: string): string {
  // Strip HTML anchor tags so the "before" snippet reads as plain text.
  return text
    .replace(/<a\s+id="[^"]*"\s*><\/a>/g, '')
    .replace(/^\s*\n/, '')
    .trim();
}

function fmtDate(v: string | Date | undefined | null): string {
  if (!v) return '';
  if (v instanceof Date) return v.toISOString().slice(0, 10);
  const m = String(v).match(/\d{4}-\d{2}-\d{2}/);
  return m ? m[0] : String(v).slice(0, 10);
}

const STATUS_LABEL: Record<string, string> = {
  draft: 'чернетка',
  review: 'на огляді',
  adopted: 'прийнято',
  rejected: 'відхилено',
};
const STATUS_COLOR: Record<string, string> = {
  draft:    'bg-amber-100 text-amber-800 dark:bg-amber-900/40 dark:text-amber-300',
  review:   'bg-blue-100 text-blue-800 dark:bg-blue-900/40 dark:text-blue-300',
  adopted:  'bg-emerald-100 text-emerald-800 dark:bg-emerald-900/40 dark:text-emerald-300',
  rejected: 'bg-ink-200 text-ink-600 dark:bg-ink-800 dark:text-ink-400',
};
const OP_LABEL: Record<string, string> = {
  redaction: 'Викласти в новій редакції',
  insert: 'Доповнити новим пунктом',
  repeal: 'Виключити',
  restore: 'Поновити',
};
const OP_BADGE: Record<string, string> = {
  redaction: 'редакція',
  insert: 'вставка',
  repeal: 'виключення',
  restore: 'поновлення',
};
const OP_COLOR: Record<string, string> = {
  redaction: 'bg-amber-100 text-amber-800 dark:bg-amber-900/40 dark:text-amber-300',
  insert: 'bg-emerald-100 text-emerald-800 dark:bg-emerald-900/40 dark:text-emerald-300',
  repeal: 'bg-red-100 text-red-800 dark:bg-red-900/40 dark:text-red-300',
  restore: 'bg-blue-100 text-blue-800 dark:bg-blue-900/40 dark:text-blue-300',
};

// Human-readable explanation for each lint code (shown under the message).
const LINT_HINT: Record<string, string> = {
  'ref-not-found': 'Перевірте номер пункту — можливо, помилка в YAML або пункт ще не написаний.',
  'new-id-collision': 'Цей ID уже існує в чинній редакції. Виберіть інший номер для нового пункту.',
  'new-id-collision-draft': 'Інший проєкт уже резервує цей номер. Узгодьте нумерацію з його автором.',
  'conflict-with-draft': 'Це попередження, не помилка. Просто означає, що перед прийняттям одного — треба буде узгодити з іншим.',
  'insert-without-anchor': 'Без «after» чи «before» незрозуміло, куди саме в текст вставляти новий пункт.',
  'insert-without-new-id': 'Без new_id інші проєкти не зможуть посилатися на ваш новий пункт.',
  'redaction-without-text': '«Викласти в редакції» вимагає поля new_text — без нього нема чим заміняти.',
  'terminology-drift': 'Сайт автоматично відстежує перейменування у попередніх амендментах.',
};
---
<Layout
  title={entry.data.title}
  description={entry.data.short_summary ?? entry.data.title}
  flavor="content"
>
  <div class="mb-4 px-3 py-2 rounded-md bg-amber-50 dark:bg-amber-900/20 border-l-2 border-amber-500 text-xs text-amber-800 dark:text-amber-200">
    <strong>Не має юридичної сили.</strong> Це робоча чернетка правки до Положення —
    публікується для обговорення і перевірки перед поданням до Мін'юсту.
  </div>

  <nav class="text-sm text-ink-500 mb-4">
    <a href="/drafts/" class="hover:text-accent-500">Проєкти</a>
    <span class="mx-2 opacity-50">›</span>
    <span>{entry.data.id}</span>
  </nav>

  <div class="flex items-baseline gap-3 mb-2 flex-wrap">
    <span class:list={['text-[10px] font-mono uppercase tracking-wider px-1.5 py-0.5 rounded', STATUS_COLOR[entry.data.status] ?? STATUS_COLOR.draft]}>{STATUS_LABEL[entry.data.status] ?? entry.data.status}</span>
    {entry.data.proposed_by && <span class="text-xs text-ink-500 font-mono">👤 {entry.data.proposed_by}</span>}
    {entry.data.proposed_at && <span class="text-xs text-ink-500 font-mono">📅 {fmtDate(entry.data.proposed_at)}</span>}
  </div>

  <h1 class="text-3xl font-bold tracking-tight mb-3">{entry.data.title}</h1>

  {entry.data.short_summary && (
    <p class="text-lg text-ink-500 leading-relaxed mb-6">{entry.data.short_summary}</p>
  )}

  <section class="my-6 rounded-md border border-ink-200 dark:border-ink-800 overflow-hidden">
    <header class="flex items-center justify-between gap-3 px-4 py-2 bg-ink-50 dark:bg-ink-900 border-b border-ink-200 dark:border-ink-800 flex-wrap">
      <div>
        <div class="text-sm font-medium">Автоперевірки</div>
        <div class="text-xs text-ink-500">Запускаються при кожному оновленні. Помилки = блокують прийняття; попередження = вимагають обговорення.</div>
      </div>
      <span class="flex items-center gap-2 text-xs">
        {errorCount > 0 && <span class="px-2 py-0.5 rounded bg-red-100 text-red-800 dark:bg-red-900/40 dark:text-red-300 font-medium">{errorCount} помилок</span>}
        {warningCount > 0 && <span class="px-2 py-0.5 rounded bg-amber-100 text-amber-800 dark:bg-amber-900/40 dark:text-amber-300 font-medium">{warningCount} попереджень</span>}
        {errorCount === 0 && warningCount === 0 && <span class="px-2 py-0.5 rounded bg-emerald-100 text-emerald-800 dark:bg-emerald-900/40 dark:text-emerald-300 font-medium">✓ без зауважень</span>}
      </span>
    </header>
    {findings.length === 0 ? (
      <div class="px-4 py-3 text-sm text-ink-500">
        Усі посилання на пункти існують, нумерація унікальна, конфліктів
        із іншими проєктами не виявлено, термінологія сучасна. Можна
        давати на огляд.
      </div>
    ) : (
      <ul class="divide-y divide-ink-200 dark:divide-ink-800 text-sm">
        {findings.map((f: any) => (
          <li class="flex gap-3 px-4 py-2">
            <span class:list={[
              'text-[10px] font-medium uppercase tracking-wider px-1.5 py-0.5 rounded h-fit',
              f.level === 'error' ? 'bg-red-100 text-red-800 dark:bg-red-900/40 dark:text-red-300' :
              f.level === 'warning' ? 'bg-amber-100 text-amber-800 dark:bg-amber-900/40 dark:text-amber-300' :
              'bg-ink-100 text-ink-600 dark:bg-ink-800 dark:text-ink-400'
            ]}>{f.level === 'error' ? 'помилка' : f.level === 'warning' ? 'попередження' : 'info'}</span>
            <div class="flex-1">
              <div>{f.message}</div>
              {LINT_HINT[f.code] && (
                <div class="text-xs text-ink-500 mt-0.5">{LINT_HINT[f.code]}</div>
              )}
            </div>
          </li>
        ))}
      </ul>
    )}
  </section>

  <h2 class="text-xl font-bold mt-8 mb-3">Операції ({entry.data.operations?.length ?? 0})</h2>
  <ol class="space-y-4 mb-8">
    {resolvedOps.map(({ op, resolved }: any, i: number) => {
      const isResolved = !!resolved;
      const targetHref = resolved
        ? `/polozhennia/${resolved.slug}/${resolved.anchor ? `#${resolved.anchor}` : ''}`
        : null;
      const beforeText = resolved?.beforeText ? strip(resolved.beforeText) : null;
      const afterText = op.new_text || op.text || null;
      return (
        <li class="rounded-md border border-ink-200 dark:border-ink-800 overflow-hidden">
          <div class="flex items-baseline gap-3 px-4 py-2 bg-ink-50 dark:bg-ink-900 border-b border-ink-200 dark:border-ink-800 flex-wrap">
            <span class="font-mono text-xs text-ink-500">№{i + 1}</span>
            <span class:list={['text-[10px] font-medium uppercase tracking-wider px-1.5 py-0.5 rounded', OP_COLOR[op.op]]}>{OP_BADGE[op.op] ?? op.op}</span>
            <span class="text-sm">{OP_LABEL[op.op] ?? op.op}</span>
            {op.target && (
              targetHref
                ? <a href={targetHref} class="font-mono text-xs text-accent-600 dark:text-accent-300 hover:underline">{op.target}</a>
                : <span class="font-mono text-xs text-red-600">{op.target} (не знайдено)</span>
            )}
            {op.after && <span class="font-mono text-xs text-ink-500">після <a href={targetHref ?? '#'} class="text-accent-600 dark:text-accent-300 hover:underline">{op.after}</a></span>}
            {op.before && <span class="font-mono text-xs text-ink-500">перед <a href={targetHref ?? '#'} class="text-accent-600 dark:text-accent-300 hover:underline">{op.before}</a></span>}
            {op.new_id && <span class="font-mono text-xs text-accent-600 dark:text-accent-300">→ {op.new_id}</span>}
            {!isResolved && (op.target || op.after || op.before) && (
              <span class="text-[10px] font-medium uppercase tracking-wider px-1.5 py-0.5 rounded bg-red-100 text-red-800 dark:bg-red-900/40 dark:text-red-300 ml-auto" title="Такого пункту немає в чинній редакції Положення">пункт не існує</span>
            )}
          </div>
          {op.rationale && (
            <div class="px-4 py-2 text-sm text-ink-600 dark:text-ink-400 border-b border-ink-200 dark:border-ink-800 italic">
              {op.rationale}
            </div>
          )}

          {(op.op === 'redaction' && beforeText && afterText) && (() => {
            const parts = wordDiff(beforeText, afterText);
            const bp = diffBefore(parts);
            const ap = diffAfter(parts);
            return (
              <div class="grid sm:grid-cols-2 gap-px bg-ink-200 dark:bg-ink-800">
                <div class="bg-white dark:bg-ink-950">
                  <div class="px-4 py-1 text-[10px] font-medium uppercase tracking-wider text-ink-500 bg-ink-50 dark:bg-ink-900 border-b border-ink-200 dark:border-ink-800">Чинна редакція</div>
                  <div class="px-4 py-3 text-sm whitespace-pre-wrap font-sans">
                    {bp.map((p: any) => (
                      p.kind === 'del'
                        ? <span class="bg-red-200 dark:bg-red-900/40 text-red-900 dark:text-red-200 line-through decoration-red-500/70">{p.value}</span>
                        : <span class="text-ink-600 dark:text-ink-400">{p.value}</span>
                    ))}
                  </div>
                </div>
                <div class="bg-white dark:bg-ink-950">
                  <div class="px-4 py-1 text-[10px] font-medium uppercase tracking-wider text-ink-500 bg-ink-50 dark:bg-ink-900 border-b border-ink-200 dark:border-ink-800">Пропонована редакція</div>
                  <div class="px-4 py-3 text-sm whitespace-pre-wrap font-sans">
                    {ap.map((p: any) => (
                      p.kind === 'add'
                        ? <span class="bg-emerald-200 dark:bg-emerald-900/40 text-emerald-900 dark:text-emerald-200">{p.value}</span>
                        : <span class="text-ink-600 dark:text-ink-400">{p.value}</span>
                    ))}
                  </div>
                </div>
              </div>
            );
          })()}

          {op.op === 'redaction' && beforeText && !afterText && (
            <pre class="px-4 py-3 text-sm whitespace-pre-wrap font-sans bg-white dark:bg-ink-950">{beforeText}</pre>
          )}

          {(op.op === 'insert' && afterText) && (
            <div class="bg-white dark:bg-ink-950">
              <div class="px-4 py-1 text-[10px] font-medium uppercase tracking-wider text-ink-500 bg-ink-50 dark:bg-ink-900 border-b border-ink-200 dark:border-ink-800">Новий пункт</div>
              <div class="px-4 py-3 text-sm whitespace-pre-wrap font-sans bg-emerald-50/40 dark:bg-emerald-900/10">{afterText}</div>
              {beforeText && (
                <details class="border-t border-ink-200 dark:border-ink-800">
                  <summary class="cursor-pointer px-4 py-2 text-xs text-ink-500 hover:text-ink-700 dark:hover:text-ink-300">Показати сусідній пункт, поряд з яким стане новий</summary>
                  <div class="px-4 pb-3 text-sm whitespace-pre-wrap font-sans text-ink-600 dark:text-ink-400">{beforeText}</div>
                </details>
              )}
            </div>
          )}

          {(op.op === 'repeal' && beforeText) && (
            <div class="bg-white dark:bg-ink-950">
              <div class="px-4 py-1 text-[10px] font-medium uppercase tracking-wider text-ink-500 bg-ink-50 dark:bg-ink-900 border-b border-ink-200 dark:border-ink-800">Що буде виключено</div>
              <div class="px-4 py-3 text-sm whitespace-pre-wrap font-sans bg-red-50/40 dark:bg-red-900/10 line-through decoration-red-400/60 text-ink-500">{beforeText}</div>
            </div>
          )}

          {(op.op === 'restore' && afterText) && (
            <div class="bg-white dark:bg-ink-950">
              <div class="px-4 py-1 text-[10px] font-medium uppercase tracking-wider text-ink-500 bg-ink-50 dark:bg-ink-900 border-b border-ink-200 dark:border-ink-800">Що буде поновлено</div>
              <div class="px-4 py-3 text-sm whitespace-pre-wrap font-sans bg-blue-50/40 dark:bg-blue-900/10">{afterText}</div>
            </div>
          )}
        </li>
      );
    })}
  </ol>

  {citation && (
    <section class="my-8 rounded-md border border-ink-200 dark:border-ink-800 overflow-hidden">
      <header class="flex items-center justify-between gap-3 px-4 py-2 bg-ink-50 dark:bg-ink-900 border-b border-ink-200 dark:border-ink-800 flex-wrap">
        <div>
          <div class="text-sm font-medium">Готовий текст для офіційного наказу</div>
          <div class="text-xs text-ink-500">Згенеровано автоматично з операцій вище — у стилі справжніх амендментів МОУ.</div>
        </div>
        <button id="copy-citation" type="button" class="text-xs px-2 py-1 rounded border border-ink-200 dark:border-ink-700 hover:border-accent-500 hover:text-accent-600">📋 Копіювати</button>
      </header>
      <pre id="citation-text" class="px-4 py-4 text-sm whitespace-pre-wrap font-sans bg-white dark:bg-ink-950 leading-relaxed">{citation}</pre>
      <footer class="px-4 py-2 text-xs text-ink-500 border-t border-ink-200 dark:border-ink-800 italic">
        Використовуйте як стартову точку: вставте в проєкт наказу-амендменту,
        вичитайте з юристом, далі — звичайна процедура узгодження і подання
        до Мін'юсту.
      </footer>
    </section>
    <script is:inline>
      document.getElementById('copy-citation')?.addEventListener('click', function () {
        const txt = document.getElementById('citation-text')?.textContent || '';
        if (navigator.clipboard?.writeText) {
          navigator.clipboard.writeText(txt).then(() => {
            this.textContent = '✓ скопійовано';
            setTimeout(() => { this.textContent = '📋 Копіювати'; }, 1500);
          });
        }
      });
    </script>
  )}

  {entry.body && entry.body.trim().length > 0 && (
    <>
      <h2 class="text-xl font-bold mt-8 mb-3">Пояснення</h2>
      <article class="prose-doc">
        <Content />
      </article>
    </>
  )}

  {entry.data.references && entry.data.references.length > 0 && (
    <>
      <h2 class="text-xl font-bold mt-8 mb-3">Посилання</h2>
      <ul class="space-y-1 text-sm">
        {entry.data.references.map((r: any) => (
          <li>
            <a href={r.url} target="_blank" rel="noopener" class="text-accent-600 dark:text-accent-300 hover:underline">{r.title}</a>
          </li>
        ))}
      </ul>
    </>
  )}

  <div class="mt-8 pt-6 border-t border-ink-200 dark:border-ink-800 flex flex-wrap gap-3">
    <a href={githubEditUrl} target="_blank" rel="noopener" class="text-sm inline-flex items-center gap-2 px-3 py-1.5 rounded-md border border-ink-200 dark:border-ink-700 hover:border-accent-500 hover:text-accent-600">
      ✏ Редагувати на GitHub
    </a>
    {entry.data.discussion?.github && (
      <a href={entry.data.discussion.github} target="_blank" rel="noopener" class="text-sm inline-flex items-center gap-2 px-3 py-1.5 rounded-md border border-ink-200 dark:border-ink-700 hover:border-accent-500 hover:text-accent-600">
        💬 Обговорення
      </a>
    )}
  </div>
</Layout>

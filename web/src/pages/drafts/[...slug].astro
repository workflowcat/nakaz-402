---
import Layout from '../../layouts/Layout.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const drafts = await getCollection('drafts');
  return drafts
    .filter(d => !d.id.toLowerCase().endsWith('readme.md'))
    .map(d => ({
      params: { slug: d.id.replace(/\.md$/, '') },
      props: { entry: d },
    }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);
const githubEditUrl = `https://github.com/workflowcat/nakaz-402/edit/main/drafts/${entry.id}`;

const STATUS_LABEL: Record<string, string> = {
  draft: 'чернетка',
  review: 'на огляді',
  adopted: 'прийнято',
  rejected: 'відхилено',
};
const STATUS_COLOR: Record<string, string> = {
  draft:    'bg-amber-100 text-amber-800 dark:bg-amber-900/40 dark:text-amber-300',
  review:   'bg-blue-100 text-blue-800 dark:bg-blue-900/40 dark:text-blue-300',
  adopted:  'bg-emerald-100 text-emerald-800 dark:bg-emerald-900/40 dark:text-emerald-300',
  rejected: 'bg-ink-200 text-ink-600 dark:bg-ink-800 dark:text-ink-400',
};
const OP_LABEL: Record<string, string> = {
  redaction: 'Викласти в редакції',
  insert: 'Доповнити',
  repeal: 'Виключити',
  restore: 'Поновити',
};
const OP_COLOR: Record<string, string> = {
  redaction: 'bg-amber-100 text-amber-800 dark:bg-amber-900/40 dark:text-amber-300',
  insert: 'bg-emerald-100 text-emerald-800 dark:bg-emerald-900/40 dark:text-emerald-300',
  repeal: 'bg-red-100 text-red-800 dark:bg-red-900/40 dark:text-red-300',
  restore: 'bg-blue-100 text-blue-800 dark:bg-blue-900/40 dark:text-blue-300',
};
---
<Layout
  title={entry.data.title}
  description={entry.data.short_summary ?? entry.data.title}
  flavor="content"
>
  <div class="mb-4 px-3 py-2 rounded-md bg-amber-50 dark:bg-amber-900/20 border-l-2 border-amber-500 text-xs text-amber-800 dark:text-amber-200">
    <strong>Не є офіційним проєктом НПА.</strong> Це машино-читабельний ескіз.
  </div>

  <nav class="text-sm text-ink-500 mb-4">
    <a href="/drafts/" class="hover:text-accent-500">Проєкти</a>
    <span class="mx-2 opacity-50">›</span>
    <span>{entry.data.id}</span>
  </nav>

  <div class="flex items-baseline gap-3 mb-2 flex-wrap">
    <span class:list={['text-[10px] font-mono uppercase tracking-wider px-1.5 py-0.5 rounded', STATUS_COLOR[entry.data.status] ?? STATUS_COLOR.draft]}>{STATUS_LABEL[entry.data.status] ?? entry.data.status}</span>
    {entry.data.proposed_by && <span class="text-xs text-ink-500 font-mono">👤 {entry.data.proposed_by}</span>}
    {entry.data.proposed_at && <span class="text-xs text-ink-500 font-mono">📅 {String(entry.data.proposed_at).slice(0, 10)}</span>}
  </div>

  <h1 class="text-3xl font-bold tracking-tight mb-3">{entry.data.title}</h1>

  {entry.data.short_summary && (
    <p class="text-lg text-ink-500 leading-relaxed mb-6">{entry.data.short_summary}</p>
  )}

  <h2 class="text-xl font-bold mt-8 mb-3">Операції ({entry.data.operations?.length ?? 0})</h2>
  <ol class="space-y-4 mb-8">
    {(entry.data.operations ?? []).map((op: any, i: number) => (
      <li class="rounded-md border border-ink-200 dark:border-ink-800 overflow-hidden">
        <div class="flex items-baseline gap-3 px-4 py-2 bg-ink-50 dark:bg-ink-900 border-b border-ink-200 dark:border-ink-800 flex-wrap">
          <span class="font-mono text-xs text-ink-500">#{i + 1}</span>
          <span class:list={['text-[10px] font-mono uppercase tracking-wider px-1.5 py-0.5 rounded', OP_COLOR[op.op]]}>{op.op}</span>
          <span class="text-sm">{OP_LABEL[op.op] ?? op.op}</span>
          {op.target && <span class="font-mono text-xs text-accent-600 dark:text-accent-300">{op.target}</span>}
          {op.after && <span class="font-mono text-xs text-ink-500">після {op.after}</span>}
          {op.before && <span class="font-mono text-xs text-ink-500">перед {op.before}</span>}
          {op.new_id && <span class="font-mono text-xs text-accent-600 dark:text-accent-300">→ {op.new_id}</span>}
        </div>
        {op.rationale && (
          <div class="px-4 py-2 text-sm text-ink-600 dark:text-ink-400 border-b border-ink-200 dark:border-ink-800 italic">
            {op.rationale}
          </div>
        )}
        {(op.new_text || op.text) && (
          <pre class="px-4 py-3 text-sm whitespace-pre-wrap font-sans bg-white dark:bg-ink-950">{op.new_text || op.text}</pre>
        )}
      </li>
    ))}
  </ol>

  {entry.body && entry.body.trim().length > 0 && (
    <>
      <h2 class="text-xl font-bold mt-8 mb-3">Пояснення</h2>
      <article class="prose-doc">
        <Content />
      </article>
    </>
  )}

  {entry.data.references && entry.data.references.length > 0 && (
    <>
      <h2 class="text-xl font-bold mt-8 mb-3">Посилання</h2>
      <ul class="space-y-1 text-sm">
        {entry.data.references.map((r: any) => (
          <li>
            <a href={r.url} target="_blank" rel="noopener" class="text-accent-600 dark:text-accent-300 hover:underline">{r.title}</a>
          </li>
        ))}
      </ul>
    </>
  )}

  <div class="mt-8 pt-6 border-t border-ink-200 dark:border-ink-800 flex flex-wrap gap-3">
    <a href={githubEditUrl} target="_blank" rel="noopener" class="text-sm inline-flex items-center gap-2 px-3 py-1.5 rounded-md border border-ink-200 dark:border-ink-700 hover:border-accent-500 hover:text-accent-600">
      ✏ Редагувати на GitHub
    </a>
    {entry.data.discussion?.github && (
      <a href={entry.data.discussion.github} target="_blank" rel="noopener" class="text-sm inline-flex items-center gap-2 px-3 py-1.5 rounded-md border border-ink-200 dark:border-ink-700 hover:border-accent-500 hover:text-accent-600">
        💬 Обговорення
      </a>
    )}
  </div>
</Layout>

---
import Layout from '../../layouts/Layout.astro';
import AmendmentHistory from '../../components/AmendmentHistory.astro';
import PunktAnchors from '../../components/PunktAnchors.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const chapters = await getCollection('polozhennia');
  return chapters.map(c => ({
    params: { slug: c.id.replace(/\.md$/, '') },
    props: { entry: c },
  }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);

const isStub = entry.data.stub === true;
const githubEditUrl = `https://github.com/workflowcat/nakaz-402/edit/main/polozhennia/${entry.id}`;

// Pull last amendment date for dateModified.
const amendmentDates = (entry.data.amended_by ?? [])
  .map((a: { date: string | Date }) => typeof a.date === 'string' ? a.date : a.date?.toISOString?.().split('T')[0])
  .filter(Boolean);
amendmentDates.sort();
const dateModified = amendmentDates[amendmentDates.length - 1] ?? '2008-08-14';

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Legislation',
  name: entry.data.title,
  alternativeHeadline: entry.data.parent ?? undefined,
  legislationIdentifier: 'z1109-08',
  legislationJurisdiction: { '@type': 'Country', name: 'Україна' },
  legislationDate: '2008-08-14',
  legislationDateOfApplicability: dateModified,
  legislationPassedBy: { '@type': 'GovernmentOrganization', name: 'Міністерство оборони України' },
  legislationLegalForce: entry.data.status === 'active' ? 'InForce' : 'NotInForce',
  inLanguage: 'uk-UA',
  isAccessibleForFree: true,
  license: 'https://creativecommons.org/publicdomain/zero/1.0/',
  url: new URL(Astro.url.pathname, 'https://nakaz-402.vercel.app').toString(),
  sameAs: entry.data.source ?? 'https://zakon.rada.gov.ua/laws/show/z1109-08',
  isPartOf: {
    '@type': 'Legislation',
    name: 'Наказ Міністерства оборони України № 402 від 14.08.2008',
    url: 'https://zakon.rada.gov.ua/laws/show/z1109-08',
  },
};
---
<Layout
  title={entry.data.title}
  description={entry.data.official_title ?? `${entry.data.parent} · ${entry.data.title}`}
  flavor="content"
  ogType="article"
  jsonLd={jsonLd}
>
  <nav class="text-sm text-ink-500 mb-4">
    {entry.data.grand_parent && (
      <>
        <a href="/polozhennia/" class="hover:text-accent-500">{entry.data.grand_parent}</a>
        <span class="mx-2 opacity-50">›</span>
      </>
    )}
    {entry.data.parent && <span>{entry.data.parent}</span>}
  </nav>

  {isStub && (
    <div class="mb-6 px-4 py-3 rounded-md bg-amber-50 dark:bg-amber-900/20 border-l-2 border-amber-500 text-sm text-amber-800 dark:text-amber-200">
      <strong>Заглушка:</strong> ця глава ще не наповнена повним текстом.
      Авторитетне джерело — <a href={entry.data.source} class="underline" target="_blank" rel="noopener">rada.gov.ua</a>.
    </div>
  )}

  {entry.data.amended_by && entry.data.amended_by.length > 0 && (
    <AmendmentHistory
      amendedBy={entry.data.amended_by}
      originalRedaction={entry.data.original_redaction}
    />
  )}

  <article class="prose-doc">
    <Content />
  </article>

  <PunktAnchors />

  <div class="mt-8 pt-6 border-t border-ink-200 dark:border-ink-800 flex flex-wrap gap-3">
    <a href={githubEditUrl} target="_blank" rel="noopener" class="text-sm inline-flex items-center gap-2 px-3 py-1.5 rounded-md border border-ink-200 dark:border-ink-700 hover:border-accent-500 hover:text-accent-600">
      ✏ Редагувати на GitHub
    </a>
    {entry.data.source && (
      <a href={entry.data.source} target="_blank" rel="noopener" class="text-sm inline-flex items-center gap-2 px-3 py-1.5 rounded-md border border-ink-200 dark:border-ink-700 hover:border-accent-500 hover:text-accent-600">
        Офіційне джерело ↗
      </a>
    )}
  </div>
</Layout>

---
import { getCollection } from 'astro:content';

// Build search index at build time
const chapters = await getCollection('polozhennia');
const nakaz = await getCollection('nakaz');
const dodatky = await getCollection('dodatky');
const rh = await getCollection('rh');
const drafts = await getCollection('drafts');

type Entry = { url: string; title: string; id: string; section: string; desc: string };
const index: Entry[] = [];

for (const c of chapters) {
  index.push({
    url: `/polozhennia/${c.id.replace(/\.md$/, '')}/`,
    title: c.data.title,
    id: c.data.id || '',
    section: c.data.parent || c.data.grand_parent || 'Положення',
    desc: c.data.official_title || c.body?.slice(0, 160).replace(/[#*\[\]]/g, '').trim() || '',
  });
}
for (const n of nakaz) {
  index.push({
    url: `/nakaz/`,
    title: n.data.title,
    id: n.data.id || 'nakaz',
    section: 'Наказ',
    desc: n.data.official_title || '',
  });
}
for (const d of dodatky) {
  if (d.data.type !== 'dodatok') continue;
  index.push({
    url: `/dodatky/${d.id.replace(/\.md$/, '')}/`,
    title: d.data.title,
    id: d.data.id || '',
    section: 'Додатки',
    desc: d.data.official_title || '',
  });
}
for (const s of rh) {
  const punktiList = s.data.punkty.map((p: any) => p.opys).join(' · ');
  index.push({
    url: `/rh/${String(s.data.stattia).padStart(3, '0')}/`,
    title: `Стаття ${s.data.stattia}. ${s.data.nazva}`,
    id: s.data.id || '',
    section: 'Розклад хвороб',
    desc: punktiList.slice(0, 200),
  });
}
for (const d of drafts) {
  index.push({
    url: `/drafts/${d.id.replace(/\.md$/, '')}/`,
    title: d.data.title,
    id: d.data.id || '',
    section: 'Драфти',
    desc: d.data.short_summary || '',
  });
}
---
<div id="search-overlay" class="fixed inset-0 z-50 hidden">
  <div class="absolute inset-0 bg-black/50 dark:bg-black/70" data-search-close></div>
  <div class="relative max-w-2xl mx-auto mt-[10vh] bg-white dark:bg-ink-900 border border-ink-200 dark:border-ink-800 rounded-lg shadow-2xl overflow-hidden">
    <div class="flex items-stretch border-b border-ink-200 dark:border-ink-800">
      <input
        type="search"
        id="search-input"
        autocomplete="off"
        spellcheck="false"
        placeholder="Шукати по сайту…  (Esc щоб закрити)"
        class="flex-1 px-5 py-4 bg-transparent text-base outline-none placeholder:text-ink-400"
      />
      <button type="button" data-search-close aria-label="Закрити" class="w-12 flex items-center justify-center text-ink-400 hover:text-ink-700 dark:hover:text-ink-200 hover:bg-ink-50 dark:hover:bg-ink-800">
        <svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M6 6l12 12M6 18L18 6"/></svg>
      </button>
    </div>
    <div id="search-results" class="max-h-[50vh] overflow-y-auto">
      <p class="px-5 py-4 text-sm text-ink-500">Друкуй щоб знайти. <kbd class="font-mono text-[11px] px-1.5 py-0.5 border border-ink-300 dark:border-ink-700 rounded">↑</kbd> <kbd class="font-mono text-[11px] px-1.5 py-0.5 border border-ink-300 dark:border-ink-700 rounded">↓</kbd> навігація, <kbd class="font-mono text-[11px] px-1.5 py-0.5 border border-ink-300 dark:border-ink-700 rounded">↵</kbd> відкрити.</p>
    </div>
  </div>
</div>

<script is:inline define:vars={{ index }}>
(function() {
  const overlay = document.getElementById('search-overlay');
  const input = document.getElementById('search-input');
  const results = document.getElementById('search-results');
  if (!overlay || !input || !results) return;

  const INDEX = index;
  let activeIdx = 0;

  function open() {
    overlay.classList.remove('hidden');
    document.body.style.overflow = 'hidden';
    setTimeout(() => input.focus(), 30);
  }
  function close() {
    overlay.classList.add('hidden');
    document.body.style.overflow = '';
    input.value = '';
    render('');
  }
  function render(q) {
    q = q.trim().toLowerCase();
    if (!q) {
      results.innerHTML = '<p class="px-5 py-4 text-sm text-ink-500">Друкуй щоб знайти.</p>';
      return;
    }
    const scored = INDEX.map(item => {
      const hay = (item.title + ' ' + item.desc + ' ' + item.id + ' ' + item.section).toLowerCase();
      let score = 0;
      if (item.title.toLowerCase().includes(q)) score += 10;
      if (item.id.toLowerCase().includes(q)) score += 8;
      if (hay.includes(q)) score += 3;
      q.split(/\s+/).forEach(t => { if (t && hay.includes(t)) score += 1; });
      return { item, score };
    }).filter(x => x.score > 0).sort((a, b) => b.score - a.score).slice(0, 30);

    if (!scored.length) {
      results.innerHTML = '<p class="px-5 py-4 text-sm text-ink-500">Нічого не знайдено.</p>';
      return;
    }
    activeIdx = 0;
    results.innerHTML = '<ul>' + scored.map((s, i) => `
      <li class="search-item ${i === 0 ? 'bg-accent-50 dark:bg-accent-900/30' : ''}" data-url="${s.item.url}">
        <a href="${s.item.url}" class="block px-5 py-2.5 hover:bg-accent-50 dark:hover:bg-accent-900/30">
          <div class="text-[11px] uppercase tracking-wider text-ink-400 mb-0.5">${s.item.section}</div>
          <div class="font-medium text-sm">${s.item.title}</div>
          ${s.item.id ? `<div class="text-xs font-mono text-ink-500 mt-0.5">${s.item.id}</div>` : ''}
          ${s.item.desc ? `<div class="text-xs text-ink-500 mt-1 line-clamp-2">${s.item.desc}</div>` : ''}
        </a>
      </li>`).join('') + '</ul>';
  }

  document.addEventListener('keydown', (e) => {
    if (e.key === '/' && !e.target.matches('input,textarea')) {
      e.preventDefault();
      open();
      return;
    }
    if (overlay.classList.contains('hidden')) return;
    if (e.key === 'Escape') { close(); return; }
    if (e.key === 'ArrowDown' || e.key === 'ArrowUp' || e.key === 'Enter') {
      const items = [...results.querySelectorAll('.search-item')];
      if (!items.length) return;
      items[activeIdx]?.classList.remove('bg-accent-50', 'dark:bg-accent-900/30');
      if (e.key === 'Enter') {
        e.preventDefault();
        const url = items[activeIdx]?.dataset.url;
        if (url) window.location.href = url;
        return;
      }
      activeIdx = e.key === 'ArrowDown' ? Math.min(items.length - 1, activeIdx + 1) : Math.max(0, activeIdx - 1);
      items[activeIdx]?.classList.add('bg-accent-50', 'dark:bg-accent-900/30');
      items[activeIdx]?.scrollIntoView({ block: 'nearest' });
      e.preventDefault();
    }
  });
  document.querySelectorAll('[data-search-close]').forEach(el => el.addEventListener('click', close));
  document.getElementById('open-search')?.addEventListener('click', open);
  input.addEventListener('input', e => render(e.target.value));
})();
</script>

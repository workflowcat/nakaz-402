---
interface Amendment {
  date: string | Date;
  order: string;
  op?: string;
  scope?: string;
}
interface Props {
  amendedBy?: Amendment[];
  originalRedaction?: string | Date;
}
const { amendedBy = [], originalRedaction } = Astro.props;

if (!amendedBy.length) {
  // Render nothing if no amendments
}

const sorted = [...amendedBy].sort((a, b) => {
  const da = typeof a.date === 'string' ? a.date : a.date.toISOString();
  const db = typeof b.date === 'string' ? b.date : b.date.toISOString();
  return da.localeCompare(db);
});
const firstDate = originalRedaction || sorted[0]?.date;
const lastDate = sorted[sorted.length - 1]?.date;

function fmtDate(d: string | Date | undefined): string {
  if (!d) return '';
  const s = typeof d === 'string' ? d : d.toISOString().split('T')[0];
  const m = s.match(/(\d{4})-(\d{2})-(\d{2})/);
  return m ? `${m[3]}.${m[2]}.${m[1]}` : s;
}
function year(d: string | Date | undefined): string {
  if (!d) return '';
  const s = typeof d === 'string' ? d : d.toISOString();
  return s.substring(0, 4);
}
function pluralUk(n: number): string {
  const m100 = n % 100, m10 = n % 10;
  if (m100 >= 11 && m100 <= 14) return 'амендментів';
  if (m10 === 1) return 'амендмент';
  if (m10 >= 2 && m10 <= 4) return 'амендменти';
  return 'амендментів';
}

const firstYear = year(firstDate);
const lastYear = year(lastDate);
const opColors: Record<string, string> = {
  insert: 'bg-emerald-100 text-emerald-800 dark:bg-emerald-900/40 dark:text-emerald-300',
  redaction: 'bg-amber-100 text-amber-800 dark:bg-amber-900/40 dark:text-amber-300',
  edit: 'bg-ink-100 text-ink-700 dark:bg-ink-800 dark:text-ink-300',
  repeal: 'bg-red-100 text-red-800 dark:bg-red-900/40 dark:text-red-300',
  restore: 'bg-blue-100 text-blue-800 dark:bg-blue-900/40 dark:text-blue-300',
};
const dotColors: Record<string, string> = {
  insert: 'bg-emerald-500',
  redaction: 'bg-amber-500',
  edit: 'bg-ink-500',
  repeal: 'bg-red-500',
  restore: 'bg-blue-500',
};

const reversed = [...sorted].reverse();
---
{amendedBy.length > 0 && (
  <details class="my-6 border border-ink-200 dark:border-ink-800 rounded-md bg-ink-50 dark:bg-ink-900 group">
    <summary class="cursor-pointer list-none px-4 py-3 flex items-center gap-3 font-medium text-sm select-none">
      <svg class="w-3 h-3 text-ink-400 transition-transform group-open:rotate-90" viewBox="0 0 12 12" fill="currentColor"><path d="M4 2l4 4-4 4z"/></svg>
      <span>📜 Історія цього пункту</span>
      <span class="ml-auto text-xs font-mono text-ink-500">{amendedBy.length} {pluralUk(amendedBy.length)} · {firstYear}—{lastYear}</span>
    </summary>
    <div class="px-4 pb-4 border-t border-ink-200 dark:border-ink-800">
      {/* Timeline */}
      <div class="relative h-10 my-3 bg-ink-100 dark:bg-ink-800 rounded-sm">
        {sorted.map(a => {
          const fd = typeof firstDate === 'string' ? new Date(firstDate).getTime() : firstDate?.getTime() || 0;
          const ld = typeof lastDate === 'string' ? new Date(lastDate).getTime() : lastDate?.getTime() || 0;
          const td = typeof a.date === 'string' ? new Date(a.date).getTime() : a.date.getTime();
          const span = Math.max(1, ld - fd);
          const offset = ((td - fd) / span) * 100;
          return (
            <span
              class:list={['absolute top-1/2 -translate-x-1/2 -translate-y-1/2 w-3 h-3 rounded-full border-2 border-white dark:border-ink-900', dotColors[a.op || 'edit']]}
              style={`left: ${offset.toFixed(1)}%`}
              title={`${fmtDate(a.date)} — наказ ${a.order} (${a.op || 'edit'})${a.scope ? ': ' + a.scope : ''}`}
            />
          );
        })}
        <span class="absolute -bottom-5 left-0 text-[10px] text-ink-500 font-mono">{firstYear}</span>
        <span class="absolute -bottom-5 right-0 text-[10px] text-ink-500 font-mono">{lastYear}</span>
      </div>
      <ul class="mt-6 space-y-1 text-sm">
        {reversed.map(a => (
          <li class="flex items-baseline gap-2 py-1 border-b border-ink-200 dark:border-ink-800 last:border-0">
            <span class="font-mono text-xs text-ink-500 min-w-[5.5rem]">{fmtDate(a.date)}</span>
            <span class:list={['text-[10px] font-mono uppercase tracking-wider px-1.5 py-0.5 rounded min-w-[4.5rem] text-center', opColors[a.op || 'edit']]}>{a.op || 'edit'}</span>
            <a href={`https://zakon.rada.gov.ua/laws/show/${a.order}`} target="_blank" rel="noopener" class="font-mono text-xs text-accent-600 dark:text-accent-300 hover:underline">{a.order}</a>
            {a.scope && <span class="text-ink-500 text-xs flex-1">{a.scope}</span>}
          </li>
        ))}
      </ul>
    </div>
  </details>
)}

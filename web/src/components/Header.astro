---
const url = Astro.url.pathname;
function active(prefix: string) {
  return url === prefix || (prefix !== '/' && url.startsWith(prefix));
}
---
<header class="sticky top-0 z-40 backdrop-blur bg-white/85 dark:bg-ink-950/85 border-b border-ink-200 dark:border-ink-800">
  <div class="max-w-7xl mx-auto px-5 h-14 flex items-center gap-6">
    <a href="/" class="flex items-center gap-2.5 font-semibold tracking-tight whitespace-nowrap hover:opacity-90">
      <span class="inline-flex w-7 h-7 items-center justify-center bg-accent-500 text-white text-xs font-bold rounded-md tracking-tighter">402</span>
      <span class="hidden sm:inline">Наказ&nbsp;МОУ&nbsp;№&nbsp;402</span>
    </a>

    <nav class="hidden md:flex items-center gap-1 flex-1 text-sm">
      <a href="/changes/" class:list={["px-3 py-1.5 rounded-md hover:bg-ink-100 dark:hover:bg-ink-800", active('/changes/') && 'text-accent-600 dark:text-accent-300 bg-accent-50 dark:bg-accent-900/20']}>Зміни</a>
      <a href="/nakaz/" class:list={["px-3 py-1.5 rounded-md hover:bg-ink-100 dark:hover:bg-ink-800", active('/nakaz/') && 'text-accent-600 dark:text-accent-300 bg-accent-50 dark:bg-accent-900/20']}>Наказ</a>
      <a href="/polozhennia/" class:list={["px-3 py-1.5 rounded-md hover:bg-ink-100 dark:hover:bg-ink-800", active('/polozhennia/') && 'text-accent-600 dark:text-accent-300 bg-accent-50 dark:bg-accent-900/20']}>Положення</a>
      <a href="/dodatky/" class:list={["px-3 py-1.5 rounded-md hover:bg-ink-100 dark:hover:bg-ink-800", active('/dodatky/') && 'text-accent-600 dark:text-accent-300 bg-accent-50 dark:bg-accent-900/20']}>Додатки</a>
      <a href="/rh/" class:list={["px-3 py-1.5 rounded-md hover:bg-ink-100 dark:hover:bg-ink-800", active('/rh/') && 'text-accent-600 dark:text-accent-300 bg-accent-50 dark:bg-accent-900/20']}>РХ</a>
      <a href="/drafts/" class:list={["px-3 py-1.5 rounded-md hover:bg-ink-100 dark:hover:bg-ink-800", active('/drafts/') && 'text-accent-600 dark:text-accent-300 bg-accent-50 dark:bg-accent-900/20']}>Драфти</a>
      <a href="/campaigns/" class:list={["px-3 py-1.5 rounded-md hover:bg-ink-100 dark:hover:bg-ink-800", active('/campaigns/') && 'text-accent-600 dark:text-accent-300 bg-accent-50 dark:bg-accent-900/20']}>Кампанії</a>
      <span class="text-ink-300 dark:text-ink-700">·</span>
      <a href="/api/docs/" class:list={["px-3 py-1.5 rounded-md hover:bg-ink-100 dark:hover:bg-ink-800", active('/api/') && 'text-accent-600 dark:text-accent-300 bg-accent-50 dark:bg-accent-900/20']}>API</a>
      <a href="/embed/" class:list={["px-3 py-1.5 rounded-md hover:bg-ink-100 dark:hover:bg-ink-800", active('/embed/') && 'text-accent-600 dark:text-accent-300 bg-accent-50 dark:bg-accent-900/20']}>Embed</a>
    </nav>

    <div class="ml-auto flex items-center gap-2">
      <button type="button" id="open-search" aria-label="Пошук" aria-keyshortcuts="/" class="inline-flex items-center gap-2 px-3 py-1.5 text-sm rounded-md border border-ink-200 dark:border-ink-700 text-ink-500 hover:border-accent-500 hover:text-accent-600 dark:hover:text-accent-300">
        <svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/></svg>
        <span class="hidden sm:inline">Пошук</span>
        <kbd class="hidden sm:inline font-mono text-[10px] px-1 py-px border border-ink-300 dark:border-ink-700 rounded bg-ink-50 dark:bg-ink-900">/</kbd>
      </button>
      <button type="button" id="theme-toggle" aria-label="Перемкнути тему" class="w-8 h-8 rounded-md hover:bg-ink-100 dark:hover:bg-ink-800 flex items-center justify-center text-ink-500">
        <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/></svg>
      </button>
      <a href="https://github.com/workflowcat/nakaz-402" target="_blank" rel="noopener" aria-label="GitHub" class="w-8 h-8 rounded-md hover:bg-ink-100 dark:hover:bg-ink-800 flex items-center justify-center text-ink-500">
        <svg viewBox="0 0 24 24" width="18" height="18" fill="currentColor"><path d="M12 0c-6.63 0-12 5.37-12 12 0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0 0 24 12c0-6.63-5.37-12-12-12z"/></svg>
      </a>
    </div>
  </div>
</header>

<script is:inline>
  document.getElementById('theme-toggle')?.addEventListener('click', () => {
    const isDark = document.documentElement.classList.toggle('dark');
    localStorage.setItem('theme', isDark ? 'dark' : 'light');
  });
</script>

---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Search from '../components/Search.astro';
import GlossaryRunner from '../components/GlossaryRunner.astro';

interface Props {
  title?: string;
  description?: string;
  flavor?: 'tool' | 'content';
  ogType?: 'website' | 'article';
  jsonLd?: Record<string, unknown> | Record<string, unknown>[];
}
const { title, description, flavor = 'tool', ogType, jsonLd } = Astro.props;
const siteName = 'Наказ МОУ № 402';
const fullTitle = title ? `${title} · ${siteName}` : siteName;
const desc = description ?? 'Машино-читабельна git-редакція Наказу МОУ № 402 (військово-лікарська експертиза)';

const siteUrl = 'https://nakaz-402.vercel.app';
const canonical = new URL(Astro.url.pathname, siteUrl).toString();
const ogImage = `${siteUrl}/og-image.svg`;
const resolvedOgType = ogType ?? (flavor === 'content' ? 'article' : 'website');

// Default JSON-LD: site-level WebSite. Pages can override.
const defaultLd = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: siteName,
  url: siteUrl,
  inLanguage: 'uk-UA',
  description: desc,
  license: 'https://creativecommons.org/publicdomain/zero/1.0/',
  isAccessibleForFree: true,
  potentialAction: {
    '@type': 'SearchAction',
    target: `${siteUrl}/?q={search_term_string}`,
    'query-input': 'required name=search_term_string',
  },
  publisher: {
    '@type': 'Organization',
    name: 'workflowcat/nakaz-402',
    url: 'https://github.com/workflowcat/nakaz-402',
  },
};
const ldData = jsonLd ?? defaultLd;
---
<!doctype html>
<html lang="uk" class="">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    <meta name="color-scheme" content="light dark" />
    <meta name="theme-color" content="#7253ed" media="(prefers-color-scheme: light)" />
    <meta name="theme-color" content="#0a0a0f" media="(prefers-color-scheme: dark)" />
    <title>{fullTitle}</title>
    <meta name="description" content={desc} />
    <link rel="canonical" href={canonical} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="alternate" type="application/rss+xml" title="Зміни до Наказу МОУ № 402 (RSS)" href="/changes/rss.xml" />
    <link rel="alternate" type="application/atom+xml" title="Зміни до Наказу МОУ № 402 (Atom)" href="/changes/atom.xml" />

    {/* OpenGraph */}
    <meta property="og:site_name" content={siteName} />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={desc} />
    <meta property="og:type" content={resolvedOgType} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:type" content="image/svg+xml" />
    <meta property="og:locale" content="uk_UA" />

    {/* Twitter Card */}
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={desc} />
    <meta name="twitter:image" content={ogImage} />

    {/* JSON-LD */}
    <script type="application/ld+json" set:html={JSON.stringify(ldData)} />

    <script is:inline>
      (() => {
        try {
          const saved = localStorage.getItem('theme');
          if (saved === 'dark' || (!saved && matchMedia('(prefers-color-scheme: dark)').matches)) {
            document.documentElement.classList.add('dark');
          }
        } catch (e) {}
      })();
    </script>
  </head>
  <body class="min-h-screen flex flex-col">
    <a href="#main" class="sr-only focus:not-sr-only focus:absolute focus:top-2 focus:left-2 focus:z-50 focus:px-3 focus:py-1 focus:bg-accent-500 focus:text-white focus:rounded">До контенту</a>
    <Header />
    <Search />
    <GlossaryRunner />
    <main id="main" class="flex-1">
      <div class:list={[
        "mx-auto px-5 py-8",
        flavor === 'content' ? 'max-w-3xl' : 'max-w-7xl',
      ]}>
        <slot />
      </div>
    </main>
    <footer class="border-t border-ink-200 dark:border-ink-800 mt-12 py-6 text-sm text-ink-500">
      <div class="max-w-7xl mx-auto px-5 flex flex-wrap gap-4 justify-between">
        <p>
          Авторитетним джерелом залишається <a href="https://zakon.rada.gov.ua/laws/show/z1109-08" class="underline hover:text-accent-500" target="_blank" rel="noopener">текст на zakon.rada.gov.ua</a>. Цей репо — інженерна реплікація під CC0.
        </p>
        <div class="flex gap-3">
          <a href="https://github.com/workflowcat/nakaz-402" class="hover:text-accent-500" target="_blank" rel="noopener">GitHub</a>
          <span class="opacity-50">·</span>
          <a href="/changes/" class="hover:text-accent-500">Зміни</a>
        </div>
      </div>
    </footer>
  </body>
</html>
